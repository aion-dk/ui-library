{
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*"
  ],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "lib": ["es2023", "esnext.array", "esnext.collection", "esnext.promise"],
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
