{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/*.spec.ts"],
  "compilerOptions": {
    "composite": false,
    "allowJs": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext",
    ],
  }
}
