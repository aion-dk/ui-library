{
  "name": "@assemblyvoting/electa-ui",
  "version": "5.6.6",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "source": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./dist/styles.css"
  },
  "browser": {
    "./styles": "./dist/styles.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test": "vitest --environment jsdom --root src/",
    "test-coverage": "vitest run --coverage --project=unit --root src/",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "prettier": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "NODE_OPTIONS=--max_old_space_size=8096 storybook build",
    "prepare": "husky",
    "precommit": "yarn lint",
    "prepublishOnly": "yarn build",
    "test-storybook": "vitest run --project=storybook"
  },
  "dependencies": {
    "@assemblyvoting/types": "^1.0.6",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/pt-mono": "^5.2.8",
    "@fontsource/rubik": "^5.2.8",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "floating-vue": "^5.2.2",
    "motion": "^12.34.4",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8"
  },
  "devDependencies": {
    "@assemblyvoting/js-client": "^6.0.0",
    "@fortawesome/fontawesome-common-types": "^7.2.0",
    "@storybook/addon-a11y": "^10.4.3",
    "@storybook/addon-docs": "^10.4.3",
    "@storybook/addon-links": "^10.4.3",
    "@storybook/addon-vitest": "^10.4.3",
    "@storybook/vue3-vite": "^10.4.3",
    "@types/bootstrap": "^5.2.10",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.10.15",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.2",
    "eslint-plugin-storybook": "^10.4.3",
    "eslint-plugin-vue": "^10.8.0",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.62.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "storybook": "^10.4.3",
    "storybook-addon-rtl": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.5"
  },
  "resolutions": {
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "$schema": "https://json.schemastore.org/package.json",
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": "eslint --cache --fix",
    "*.{js,css,md}": "prettier --write"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "bundledDependencies": [
    "bootstrap"
  ]
}
