{
  "name": "@assemblyvoting/electa-ui",
  "version": "5.5.4-beta.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "source": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./dist/styles.css"
  },
  "browser": {
    "./styles": "./dist/styles.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "test": "vitest --environment jsdom --root src/",
    "test-coverage": "vitest run --coverage --root src/",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prettier": "prettier --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "NODE_OPTIONS=--max_old_space_size=8096 storybook build",
    "prepare": "husky",
    "precommit": "yarn lint",
    "prepublishOnly": "yarn build",
    "test-storybook": "test-storybook --maxWorkers 1 --testTimeout=60000",
    "test-storybook-coverage": "test-storybook --maxWorkers 1 --coverage --testTimeout=60000"
  },
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/pt-mono": "^5.2.8",
    "@fontsource/rubik": "^5.2.8",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "floating-vue": "^5.2.2",
    "motion": "^12.34.4",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8"
  },
  "devDependencies": {
    "@assemblyvoting/js-client": "^5.3.3-beta.1",
    "@chromatic-com/storybook": "^5.1.2",
    "@fortawesome/fontawesome-common-types": "^7.2.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/test-runner": "^0.24.3",
    "@storybook/vue3-vite": "^10.3.5",
    "@types/bootstrap": "^5.2.10",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.10.15",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.0.2",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-vue": "^10.8.0",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "storybook": "^10.3.5",
    "storybook-addon-rtl": "^3.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "lint-staged": {
    "*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts}": "eslint --cache --fix",
    "*.{js,css,md}": "prettier --write"
  },
  "bundledDependencies": [
    "bootstrap"
  ]
}
